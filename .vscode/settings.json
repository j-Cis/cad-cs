{
	"search.exclude": {
		"**": true,
		"src/**": false,
		"example/**": false,
		"ARCHITECTURE.md": false,
		"TODO.md": false,
		"ROADMAP.md": false,
		"README.md": false
	},
	"files.readonlyInclude": {
		"**/*.lock": true,
		".git/**": true,
		".err/**": true,
		".history/**": true,
		"target/**": true,
		"LICENSE-APACHE": true,
		"LICENSE-MIT": true
	},
	 // Wykluczenie całego folderu z walidacji lintera
	"files.watcherExclude": {
		"**/.temp/**": true,
		"**/.err/**": true,
		"**/.git/**": true,
		"**/.history/**": true
	},
	"markdownlint.ignore": [
		".temp/**",
		".err/**",
		".git/**",
		".history/**"
	],
	"markdownlint.ignorePatterns": [
		".temp/**/*.md",
		".err/**/*.md",
		".git/**/*.md",
		".history/**/*.md"
	],

	// --- FORMATOWANIE I TABULATORY ---
	// Wymuszamy tabulatory zamiast spacji (zgodnie z .rustfmt.toml)
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.detectIndentation": false,
	
	// --- WIZUALIZACJA STRUKTURY KODU ---
    
    // Pionowe linie (Rulers) - ustawiamy na 100 zgodnie z rustfmt
    "editor.rulers": [
		100,
		150,
		200
	],

    // Podświetlanie aktywnych wcięć (ułatwia połapanie się w blokach)
    "editor.guides.bracketPairs": "active",
    "editor.guides.indentation": true,
    "editor.guides.highlightActiveIndentation": true,

    // Pokazywanie białych znaków (kropki dla spacji, strzałki dla tabulatorów)
    // "boundary" pokazuje je tylko tam, gdzie są wcięcia/końce linii
    "editor.renderWhitespace": "boundary",

    // Renderowanie małej strzałki na końcach linii (ułatwia nawigację)
    "editor.renderLineHighlight": "all",
	"actionButtons": {
		"defaultColor": "none",
		"loadNpmCommands": false,
		"reloadButton": null,
		"commands": [
			{
				"name": "$(terminal) Terminal w Oknie",
				"color": "#00FF00",
				"useVsCodeApi": true,
				"command": "workbench.action.terminal.newInNewWindow",
				"tooltip": "Otwiera nowy terminal w osobnym oknie"
			}
		]
	}
}